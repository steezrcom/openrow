DATABASE_URL=postgres://openrow:openrow@localhost:5432/openrow?sslmode=disable

# 32-byte base64-encoded key used to encrypt stored API keys and connector
# secrets. Generate once with: `openssl rand -base64 32`. Rotating this key
# invalidates every stored secret (they'll decrypt to garbage), so keep it safe.
OPENROW_SECRET_KEY=

# Optional: fallback LLM when a workspace has no per-tenant config.
# Used for dev convenience. Each workspace can override via Settings → LLM.
ANTHROPIC_API_KEY=

HTTP_ADDR=:8080
APP_URL=http://localhost:5173
SECURE_COOKIES=false
LOG_LEVEL=info
